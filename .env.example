# Phase 0 has no required runtime secrets.
# Future variables must be documented before use and real values must stay out of Git.
APP_ENV=development
LOG_LEVEL=INFO

# Local Docker Compose database only. Copy this file to .env and replace the
# example password. Never reuse this credential outside local development.
POSTGRES_DB=complaint_triage
POSTGRES_USER=complaint_triage
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=55432
